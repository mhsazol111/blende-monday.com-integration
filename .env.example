# ──────────────────────────────────────────────────────────────────────────
# monday-automation-service — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── monday.com API ──────────────────────────────────────────────────────────
# Personal/API token (Admin > API). The old token committed in the PHP plugin
# is considered compromised — generate a NEW one and put it here.
MONDAY_API_TOKEN=
MONDAY_API_URL=https://api.monday.com/v2

# Production board (the real one). Used in Phase 6 cutover.
MONDAY_BOARD_ID=18403436566
# Test board used for all wiring/verification until cutover.
MONDAY_TEST_BOARD_ID=

# ── HTTP server (webhook ingress) ────────────────────────────────────────────
PORT=3000
# Shared secret appended to the webhook URL (?secret=...) and/or sent as a
# header, verified by the ingress before processing. Generate a random string.
WEBHOOK_SHARED_SECRET=

# ── Persistence ──────────────────────────────────────────────────────────────
# Path to the local SQLite database file (created on first run).
DATABASE_PATH=./data/automation.sqlite

# ── Rules & scheduler ────────────────────────────────────────────────────────
RULES_PATH=./config/rules.json
WORKER_INTERVAL_MS=60000        # how often the worker polls for due actions
WORKER_MAX_ATTEMPTS=3           # send attempts before an action is marked failed
WORKER_RETRY_BACKOFF_MS=300000  # backoff per attempt (× attempt number)

# ── Slack ────────────────────────────────────────────────────────────────────
# Default incoming-webhook URL (rules may override per-action). The URL
# committed in the PHP plugin is considered compromised — regenerate it.
SLACK_WEBHOOK_URL=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Monday Automation
SMTP_FROM_EMAIL=no-reply@example.com

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
